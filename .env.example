# ================================================================
# Variables publiques (exposées au navigateur)
# ================================================================
# Supabase project → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Supabase project → Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ================================================================
# Variables SERVEUR (jamais exposées au navigateur)
# ================================================================
# Supabase project → Settings → API → "secret" key (sb_secret_...)
# N'UTILISE JAMAIS cette clé côté client. Pas de prefixe NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Mot de passe pour accéder à la page /admin (cookie-based)
ADMIN_PASSWORD=change-me-please
