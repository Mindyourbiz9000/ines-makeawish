# ================================================================
# Les 2 SEULES variables nécessaires.
# Les deux sont utilisées uniquement côté serveur.
# ================================================================

# Supabase → Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase → Settings → API → Secret keys → sb_secret_...
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx
